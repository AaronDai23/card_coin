# Uncomment this line to define a global platform for your project
 platform :ios, '15.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

def common_pods
  # chipcore_sdk 依赖（TangemSdk、BitcoinCore 等旧依赖已随 Tangem SDK 一同移除）
end

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!
  use_modular_headers!
  # chipcore_sdk 依赖
  pod 'CryptoSwift', '~> 1.8'
  # 手动下载 AppsFlyerFramework 二进制包以避免 GitHub 下载失败
  # 下载地址: https://github.com/AppsFlyerSDK/AppsFlyerFramework/releases/download/6.14.3/AppsFlyerLib-Binaries.zip
  # 将文件保存到本地后，将下方路径替换为实际路径，然后取消注释：
  # pod 'AppsFlyerFramework', '6.14.3', :http => 'file:///Users/daipeiqiong/Downloads/AppsFlyerLib-Binaries.zip'

  # Explicitly declare app_settings so CocoaPods always includes it, regardless of
  # whether flutter_install_all_ios_pods picks it up (it can be silently dropped
  # when pod install re-resolves with --repo-update on CI).
  pod 'app_settings', :path => '.symlinks/plugins/app_settings/ios'

  common_pods
  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
  end
  
#  if target.name == 'open_settings_plus'
#    target.build_configurations.each do |config|
#      config.build_settings['DEFINES_MODULE'] = 'NO'
#      config.build_settings['CLANG_ENABLE_MODULES'] = 'NO'
#      config.build_settings['SWIFT_ENABLE_MODULES'] = 'NO'
#    end
#  end
  
  installer.pods_project.build_configurations.each do |config|
      if config.name.include?("Debug")
          config.build_settings['GCC_OPTIMIZATION_LEVEL'] = '0'
          config.build_settings['SWIFT_OPTIMIZATION_LEVEL'] = '-Onone'
          config.build_settings['ONLY_ACTIVE_ARCH'] = 'YES'
          config.build_settings['ENABLE_TESTABILITY'] = 'YES'
          config.build_settings['SWIFT_COMPILATION_MODE'] = 'Incremental'
      end

      config.build_settings['DEAD_CODE_STRIPPING'] = 'YES'
  end

  installer.pods_project.targets.each do |target|
    # app_settings: disable BUILD_LIBRARY_FOR_DISTRIBUTION (library evolution mode breaks
    # Clang @import for Swift pods with @preconcurrency conformances in Archive builds)
    # and keep DEFINES_MODULE so the framework module map is generated correctly.
    if target.name == 'app_settings'
      target.build_configurations.each do |config|
        config.build_settings['DEFINES_MODULE'] = 'YES'
        config.build_settings['BUILD_LIBRARY_FOR_DISTRIBUTION'] = 'NO'
      end
    else
      target.build_configurations.each do |config|
        config.build_settings['BUILD_LIBRARY_FOR_DISTRIBUTION'] = 'YES'
      end
    end

    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
    end

    if target.respond_to?(:product_type) and target.product_type == "com.apple.product-type.bundle"
      target.build_configurations.each do |config|
        config.build_settings['CODE_SIGNING_ALLOWED'] = 'NO'
      end
    end

  end
end
