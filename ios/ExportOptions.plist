<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- 发布方式: app-store-connect / ad-hoc / enterprise / development -->
    <key>method</key>
    <string>app-store-connect</string>

    <key>teamID</key>
    <string>G76B76R439</string>

    <!-- automatic: Xcode 通过 ASC API Key 自动处理 Runner 和 Clip 两个 target 的签名，
         无需为每个 target 单独指定 Profile UUID。
         若切回 manual，需在 provisioningProfiles 中同时提供
         com.cardbase.app 和 com.cardbase.app.Clip 的 UUID。 -->
    <key>signingStyle</key>
    <string>automatic</string>

    <key>signingCertificate</key>
    <string>Apple Distribution</string>

    <key>stripSwiftSymbols</key>
    <true/>

    <key>uploadBitcode</key>
    <false/>

    <key>compileBitcode</key>
    <false/>

    <key>uploadSymbols</key>
    <true/>
</dict>
</plist>
